[debug] [2026-06-15T17:41:16.283Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/routemaat/rulesets {"name":"projects/routemaat/rulesets/4b438077-0a49-4c68-931d-bff3385c1b13","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function tripPath(tripId) {\n      return /databases/$(database)/documents/trips/$(tripId);\n    }\n\n    function memberPath(tripId, userId) {\n      return /databases/$(database)/documents/trips/$(tripId)/members/$(userId);\n    }\n\n    function currentMemberPath(tripId) {\n      return memberPath(tripId, request.auth.uid);\n    }\n\n    function isValidRole(role) {\n      return role in ['owner', 'admin', 'editor', 'viewer'];\n    }\n\n    function isTripMember(tripId) {\n      return signedIn() && exists(currentMemberPath(tripId));\n    }\n\n    function isTripCreator(tripId) {\n      return signedIn()\n        && exists(tripPath(tripId))\n        && get(tripPath(tripId)).data.createdBy == request.auth.uid;\n    }\n\n    function canReadTrip(tripId) {\n      return isTripMember(tripId) || isTripCreator(tripId);\n    }\n\n    function getTripRole(tripId) {\n      return get(currentMemberPath(tripId)).data.role;\n    }\n\n    function isOwner(tripId) {\n      return isTripCreator(tripId)\n        || (isTripMember(tripId) && getTripRole(tripId) == 'owner');\n    }\n\n    function isAdmin(tripId) {\n      return isTripMember(tripId) && getTripRole(tripId) == 'admin';\n    }\n\n    function canEditTripContent(tripId) {\n      return isTripMember(tripId)\n        && getTripRole(tripId) in ['owner', 'admin', 'editor'];\n    }\n\n    function canManageTripMembers(tripId) {\n      return isTripMember(tripId)\n        && getTripRole(tripId) in ['owner', 'admin'];\n    }\n\n    function hasOptionalString(data, field) {\n      return !data.keys().hasAny([field]) || data[field] is string;\n    }\n\n    function hasOptionalBool(data, field) {\n      return !data.keys().hasAny([field]) || data[field] is bool;\n    }\n\n    function hasOptionalList(data, field) {\n      return !data.keys().hasAny([field]) || data[field] is list;\n    }\n\n    function hasOptionalNullableString(data, field) {\n      return !data.keys().hasAny([field])\n        || data[field] == null\n        || data[field] is string;\n    }\n\n    function hasRequiredString(data, field) {\n      return data.keys().hasAny([field]) && data[field] is string;\n    }\n\n    function validTripData(data) {\n      return data.keys().hasAll([\n          'title',\n          'destination',\n          'startDate',\n          'endDate',\n          'createdBy'\n        ])\n        && data.title is string\n        && data.destination is string\n        && data.startDate is string\n        && data.endDate is string\n        && data.createdBy is string\n        && hasOptionalString(data, 'description')\n        && hasOptionalString(data, 'countryCode')\n        && hasOptionalString(data, 'languageCode')\n        && hasOptionalString(data, 'languageName')\n        && hasOptionalString(data, 'nativeLanguageName')\n        && hasOptionalList(data, 'memberIds');\n    }\n\n    function validTripCreate(data) {\n      return validTripData(data)\n        && data.createdBy == request.auth.uid;\n    }\n\n    function validTripUpdate(data) {\n      return validTripData(data)\n        && data.createdBy == resource.data.createdBy;\n    }\n\n    function validMemberData(data) {\n      return data.keys().hasAll(['role'])\n        && isValidRole(data.role)\n        && hasOptionalNullableString(data, 'displayName')\n        && hasOptionalNullableString(data, 'email')\n        && hasOptionalNullableString(data, 'photoURL')\n        && hasOptionalString(data, 'inviteId');\n    }\n\n    function invitePath(tripId, inviteId) {\n      return /databases/$(database)/documents/trips/$(tripId)/invites/$(inviteId);\n    }\n\n    function inviteMatchesSelfAccept(tripId, data) {\n      return hasRequiredString(data, 'inviteId')\n        && exists(invitePath(tripId, data.inviteId))\n        && get(invitePath(tripId, data.inviteId)).data.status == 'pending'\n        && get(invitePath(tripId, data.inviteId)).data.email == data.email\n        && get(invitePath(tripId, data.inviteId)).data.email\n          == request.auth.token.email\n        && get(invitePath(tripId, data.inviteId)).data.role == data.role;\n    }\n\n    function canAcceptInviteAsMember(tripId, userId, data) {\n      return signedIn()\n        && request.auth.uid == userId\n        && request.auth.token.email != null\n        && data.role != 'owner'\n        && inviteMatchesSelfAccept(tripId, data);\n    }\n\n    function canAssignMemberRole(tripId, role) {\n      return isOwner(tripId)\n        || (isAdmin(tripId) && role != 'owner');\n    }\n\n    function canChangeMemberRole(tripId, oldRole, newRole) {\n      return isOwner(tripId)\n        || (isAdmin(tripId) && oldRole != 'owner' && newRole != 'owner');\n    }\n\n    function canDeleteMemberWithRole(tripId, userId, role) {\n      return (isOwner(tripId) && role != 'owner')\n        || (isAdmin(tripId) && role != 'owner')\n        || (signedIn() && request.auth.uid == userId && role != 'owner')\n        || (isOwner(tripId) && !existsAfter(tripPath(tripId)));\n    }\n\n    function validMembershipData(data, tripId) {\n      return data.keys().hasAll([\n          'tripId',\n          'role',\n          'title',\n          'destination',\n          'startDate',\n          'endDate'\n        ])\n        && data.tripId == tripId\n        && isValidRole(data.role)\n        && data.title is string\n        && data.destination is string\n        && data.startDate is string\n        && data.endDate is string;\n    }\n\n    function targetMemberAfterMatchesMembership(tripId, userId) {\n      return existsAfter(memberPath(tripId, userId))\n        && getAfter(memberPath(tripId, userId)).data.role\n          == request.resource.data.role;\n    }\n\n    function canWriteMembership(tripId, userId) {\n      return canManageTripMembers(tripId)\n        || (signedIn()\n          && request.auth.uid == userId\n          && targetMemberAfterMatchesMembership(tripId, userId));\n    }\n\n    function inviteEmailMatches(data) {\n      return signedIn()\n        && request.auth.token.email != null\n        && data.email == request.auth.token.email;\n    }\n\n    function validInviteData(data) {\n      return data.keys().hasAll([\n          'email',\n          'role',\n          'status',\n          'invitedBy'\n        ])\n        && data.email is string\n        && isValidRole(data.role)\n        && data.status in ['pending', 'accepted']\n        && data.invitedBy is string;\n    }\n\n    function validInviteCreate(data) {\n      return validInviteData(data)\n        && data.status == 'pending'\n        && data.invitedBy == request.auth.uid;\n    }\n\n    function validInviteAcceptance() {\n      return validInviteData(request.resource.data)\n        && resource.data.status == 'pending'\n        && request.resource.data.status == 'accepted'\n        && request.resource.data.email == resource.data.email\n        && request.resource.data.role == resource.data.role\n        && request.resource.data.invitedBy == resource.data.invitedBy;\n    }\n\n    function isValidIdeaCategory(category) {\n      return category in [\n        'sightseeing',\n        'restaurant',\n        'hotel',\n        'shop',\n        'activity',\n        'transport',\n        'practical',\n        'language',\n        'custom',\n        'document',\n        'other'\n      ];\n    }\n\n    function isValidIdeaStatus(status) {\n      return status in ['idea', 'maybe', 'planned', 'booked', 'skipped'];\n    }\n\n    function isValidIdeaPriority(priority) {\n      return priority in ['low', 'medium', 'high'];\n    }\n\n    function validIdeaData(data, tripId) {\n      return data.keys().hasAll(['title'])\n        && data.title is string\n        && (!data.keys().hasAny(['tripId']) || data.tripId == tripId)\n        && (!data.keys().hasAny(['category'])\n          || isValidIdeaCategory(data.category))\n        && (!data.keys().hasAny(['status'])\n          || isValidIdeaStatus(data.status))\n        && (!data.keys().hasAny(['priority'])\n          || isValidIdeaPriority(data.priority))\n        && hasOptionalString(data, 'description')\n        && hasOptionalString(data, 'city')\n        && hasOptionalString(data, 'locationName')\n        && hasOptionalString(data, 'googleMapsUrl')\n        && hasOptionalString(data, 'websiteUrl')\n        && hasOptionalString(data, 'customsNotes')\n        && hasOptionalString(data, 'notes')\n        && hasOptionalString(data, 'scheduleDate')\n        && hasOptionalString(data, 'startTime')\n        && hasOptionalString(data, 'endTime')\n        && hasOptionalBool(data, 'showInSchedule')\n        && hasOptionalList(data, 'tags');\n    }\n\n    function validIdeaCreate(data, tripId) {\n      return validIdeaData(data, tripId)\n        && data.keys().hasAll([\n          'tripId',\n          'category',\n          'status',\n          'priority',\n          'tags',\n          'showInSchedule',\n          'addedBy'\n        ])\n        && data.addedBy == request.auth.uid;\n    }\n\n    function validIdeaUpdate(data, tripId) {\n      return validIdeaData(data, tripId)\n        && data.addedBy == resource.data.addedBy;\n    }\n\n    function isValidPhraseCategory(category) {\n      return category in [\n        'general',\n        'restaurant',\n        'hotel',\n        'transport',\n        'temple',\n        'onsen',\n        'shop',\n        'emergency',\n        'custom'\n      ];\n    }\n\n    function validPhraseData(data, tripId) {\n      return data.keys().hasAll(['dutchText', 'translatedText', 'favorite'])\n        && data.dutchText is string\n        && data.translatedText is string\n        && data.favorite is bool\n        && (!data.keys().hasAny(['tripId']) || data.tripId == tripId)\n        && (!data.keys().hasAny(['category'])\n          || isValidPhraseCategory(data.category))\n        && hasOptionalString(data, 'nativeText')\n        && hasOptionalString(data, 'pronunciation')\n        && hasOptionalString(data, 'notes');\n    }\n\n    function validPhraseCreate(data, tripId) {\n      return validPhraseData(data, tripId)\n        && data.keys().hasAll(['tripId', 'category', 'createdBy'])\n        && data.createdBy == request.auth.uid;\n    }\n\n    function validPhraseUpdate(data, tripId) {\n      return validPhraseData(data, tripId)\n        && data.createdBy == resource.data.createdBy;\n    }\n\n    match /users/{userId} {\n      // Userprofielen blijven prive. Direct zoeken in users op e-mail voor\n      // uitnodigen is hiermee niet toegestaan; gebruik daarvoor later een\n      // beperkte service/Cloud Function of een aparte publieke lookup-index.\n      allow read: if signedIn() && request.auth.uid == userId;\n      allow create, update: if signedIn()\n        && request.auth.uid == userId\n        && hasOptionalNullableString(request.resource.data, 'displayName')\n        && hasOptionalNullableString(request.resource.data, 'email')\n        && hasOptionalNullableString(request.resource.data, 'photoURL');\n      allow delete: if signedIn() && request.auth.uid == userId;\n\n      match /tripMemberships/{tripId} {\n        allow read: if signedIn() && request.auth.uid == userId;\n        // Zelf accepteren via pending invite vraagt in de huidige client om\n        // meerdere writes zonder inviteId in het member/membership-pad. Dat is\n        // niet veilig te bewijzen in rules; gebruik hiervoor later een\n        // deterministische invite of app-service/Cloud Function.\n        allow create, update: if validMembershipData(request.resource.data, tripId)\n          && canWriteMembership(tripId, userId);\n        allow delete: if canDeleteMemberWithRole(\n          tripId,\n          userId,\n          resource.data.role\n        );\n      }\n    }\n\n    match /trips/{tripId} {\n      allow read: if isTripMember(tripId)\n        || (signedIn() && resource.data.createdBy == request.auth.uid);\n      allow create: if signedIn() && validTripCreate(request.resource.data);\n      allow update: if canManageTripMembers(tripId)\n        && validTripUpdate(request.resource.data);\n      allow delete: if isOwner(tripId);\n\n      match /members/{userId} {\n        allow read: if canReadTrip(tripId);\n        allow create: if validMemberData(request.resource.data)\n          && (\n            (canManageTripMembers(tripId)\n              && canAssignMemberRole(tripId, request.resource.data.role))\n            || canAcceptInviteAsMember(\n              tripId,\n              userId,\n              request.resource.data\n            )\n            || (signedIn()\n              && request.auth.uid == userId\n              && request.resource.data.role == 'owner'\n              && existsAfter(tripPath(tripId))\n              && getAfter(tripPath(tripId)).data.createdBy == request.auth.uid)\n          );\n        allow update: if validMemberData(request.resource.data)\n          && canChangeMemberRole(\n            tripId,\n            resource.data.role,\n            request.resource.data.role\n          );\n        allow delete: if canDeleteMemberWithRole(\n          tripId,\n          userId,\n          resource.data.role\n        );\n      }\n\n      match /invites/{inviteId} {\n        // E-mailmatching gebruikt de e-mailclaim uit Firebase Auth exact.\n        // De app slaat e-mails lowercase op; als providers ooit andere casing\n        // leveren, normaliseer dit via app-service of Cloud Function.\n        allow read: if canManageTripMembers(tripId)\n          || inviteEmailMatches(resource.data);\n        allow create: if canManageTripMembers(tripId)\n          && validInviteCreate(request.resource.data);\n        allow update: if (canManageTripMembers(tripId)\n            && validInviteData(request.resource.data))\n          || (inviteEmailMatches(resource.data) && validInviteAcceptance());\n        allow delete: if canManageTripMembers(tripId);\n      }\n\n      match /ideas/{ideaId} {\n        allow read: if canReadTrip(tripId);\n        allow create: if canEditTripContent(tripId)\n          && validIdeaCreate(request.resource.data, tripId);\n        allow update: if canEditTripContent(tripId)\n          && validIdeaUpdate(request.resource.data, tripId);\n        allow delete: if canEditTripContent(tripId);\n      }\n\n      match /phrases/{phraseId} {\n        allow read: if canReadTrip(tripId);\n        allow create: if canEditTripContent(tripId)\n          && validPhraseCreate(request.resource.data, tripId);\n        allow update: if canEditTripContent(tripId)\n          && validPhraseUpdate(request.resource.data, tripId);\n        allow delete: if canEditTripContent(tripId);\n      }\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-15T17:41:17.414559Z","metadata":{"services":["cloud.firestore"]}}
