[debug] [2026-06-15T21:09:57.463Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/routemaat/rulesets {"name":"projects/routemaat/rulesets/035434de-905e-4e06-9320-2881a7a753af","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function memberPath(tripId) {\n      return /databases/(default)/documents/trips/$(tripId)/members/$(request.auth.uid);\n    }\n\n    function tripPath(tripId) {\n      return /databases/(default)/documents/trips/$(tripId);\n    }\n\n    function isTripMember(tripId) {\n      return signedIn() && firestore.exists(memberPath(tripId));\n    }\n\n    function isTripCreator(tripId) {\n      return signedIn()\n        && firestore.exists(tripPath(tripId))\n        && firestore.get(tripPath(tripId)).data.createdBy == request.auth.uid;\n    }\n\n    function memberRole(tripId) {\n      return firestore.get(memberPath(tripId)).data.role;\n    }\n\n    function canReadTripFiles(tripId) {\n      return isTripMember(tripId) || isTripCreator(tripId);\n    }\n\n    function canWriteTripFiles(tripId) {\n      return isTripCreator(tripId)\n        || (isTripMember(tripId)\n          && memberRole(tripId) in ['owner', 'admin', 'editor']);\n    }\n\n    function isSupportedContentType(contentType) {\n      return contentType in [\n        'application/pdf',\n        'image/jpeg',\n        'image/png',\n        'image/webp',\n        'text/plain',\n        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',\n        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',\n        'application/vnd.openxmlformats-officedocument.presentationml.presentation'\n      ];\n    }\n\n    function isValidDocumentFile() {\n      return request.resource != null\n        && request.resource.size < 10 * 1024 * 1024\n        && isSupportedContentType(request.resource.contentType);\n    }\n\n    match /trips/{tripId}/documents/{documentId}/{fileName} {\n      allow read: if canReadTripFiles(tripId);\n      allow create, update: if canWriteTripFiles(tripId)\n        && isValidDocumentFile();\n      allow delete: if canWriteTripFiles(tripId);\n    }\n\n    match /{allPaths=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-06-15T21:09:58.788911Z","metadata":{"services":["firebase.storage"]}}
